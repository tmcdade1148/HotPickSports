# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# Expo modules autolinking. Required so ExpoModulesCore installs the `expo`
# JSI global (ExpoGlobal) at native startup — without this, every expo-* module
# (expo-notifications/-device/-updates/-asset/-font/-constants) crashes on iOS
# with "Cannot read property 'EventEmitter' of undefined". Android installs the
# same global via its autolinked ExpoModulesCore ReactPackage, so it needs no
# equivalent — this gap is iOS-only.
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'HotPickSports' do
  use_expo_modules!
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Expose React-RCTLinking as a Swift module so AppDelegate can import it
    # Generate dSYMs for all pods (eliminates App Store Connect upload warnings)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
        # Xcode 16+/26 enables "Explicitly Built Modules" by default. With it on,
        # the dependency scanner expects every pod's module map to exist up front,
        # but CocoaPods generates them later in the build — so it fails with
        # "module map file ... not found" (e.g. RCTSwiftUI.modulemap). Disable it
        # for BOTH the C/Obj-C (CLANG) and the Swift compilers; setting only the
        # CLANG flag leaves Swift pods (RCTSwiftUI, etc.) still broken.
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
        if target.name == 'React-RCTLinking'
          config.build_settings['DEFINES_MODULE'] = 'YES'
        end
      end
    end
  end
end
