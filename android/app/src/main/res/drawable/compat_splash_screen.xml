<?xml version="1.0" encoding="utf-8"?>
<!-- Override react-native-bootsplash's compat_splash_screen.xml
     Library default: 288dp = larger than native splash circle.
     Our override: 240dp = matches native splash icon area exactly.
     The circle (160dp/66.7%) is baked into the bootsplash_logo PNG. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" android:opacity="opaque">
    <item android:gravity="fill">
        <color android:color="?attr/bootSplashBackground" />
    </item>
    <item
        android:drawable="?bootSplashLogo"
        android:gravity="center"
        android:width="240dp"
        android:height="240dp" />
</layer-list>
