<?xml version="1.0" encoding="utf-8"?>
<!-- Override react-native-bootsplash's compat_splash_screen.xml
     Library default: 288dp logo = "growing" effect vs native 160dp circle mask.
     Our override: 160dp logo = matches Android 12+ native splash circle exactly. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" android:opacity="opaque">
    <item android:gravity="fill">
        <color android:color="?attr/bootSplashBackground" />
    </item>
    <item
        android:drawable="?bootSplashLogo"
        android:gravity="center"
        android:width="160dp"
        android:height="160dp" />
</layer-list>
